# Flynn AI Environment Variables

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Supabase Auth → "Send SMS" hook secret (Standard Webhooks format, e.g. "v1,whsec_...").
# Set in Supabase Dashboard → Auth → Hooks → Send SMS Hook, then mirror here + on Fly.
SUPABASE_AUTH_SMS_HOOK_SECRET=
APP_BASE_URL=https://flynnai-telephony.fly.dev
VOICEMAIL_STORAGE_BUCKET=voicemails
VOICEMAIL_SIGNED_URL_TTL_SECONDS=3600
VOICEMAIL_RETENTION_DAYS=30

# LLM Configuration
# Note: Voice receptionist now uses Deepgram Voice Agent API with Gemini
# OpenAI API key still needed for job extraction and other AI features
OPENAI_API_KEY=your_openai_api_key_here
# Gemini for Voice Agent LLM (Google AI Studio - not Vertex AI)
GEMINI_API_KEY=your_gemini_api_key_here
# Receptionist model is now fixed to gemini-2.5-flash via Deepgram Voice Agent API
JOB_EXTRACTION_MODEL=gpt-4o-mini

# Expo client LLM configuration (avoid setting secrets in production builds)
EXPO_PUBLIC_LLM_PROVIDER=
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_LLM_CHAT_MODEL=

# Twilio Configuration (backend) — Twilio is Flynn's sole telephony/SMS provider.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SERVER_PUBLIC_URL=
# TWILIO_FROM_NUMBER     — E.164 sender for OTP + SMS-link fallback (AU Mobile, +614xxxxxxxx).
# TWILIO_AU_BUNDLE_SID   — Approved AU regulatory bundle SID (required to provision AU numbers).
# TWILIO_AU_ADDRESS_SID  — Twilio Address SID tied to the AU bundle.
TWILIO_FROM_NUMBER=
TWILIO_AU_BUNDLE_SID=
TWILIO_AU_ADDRESS_SID=

# Dev shared-number mode — when TELNYX_DEV_MODE=true, users whose email is in
# DEV_TEST_EMAILS (comma-separated) are assigned TELNYX_DEV_SHARED_NUMBER instead
# of provisioning a real number. Used to repeat onboarding tests without burning
# $$/number. (The TELNYX_DEV_* names are legacy — kept so deployed secrets keep
# working; provisioning itself is Twilio now.)
TELNYX_DEV_MODE=false
TELNYX_DEV_SHARED_NUMBER=
TELNYX_DEV_SHARED_SID=
DEV_TEST_EMAILS=

# Apple App Store JWS verification — point at AppleRootCA-G3.cer (PEM) before
# production. Without this, JWS signature/chain checks are SKIPPED (sandbox-only).
# Download: https://www.apple.com/certificateauthority/AppleRootCA-G3.cer
# Convert: openssl x509 -inform DER -in AppleRootCA-G3.cer -out AppleRootCA-G3.pem
APPLE_ROOT_CA_PATH=
APPLE_BUNDLE_ID=com.flynnai.app
APPLE_ENVIRONMENT=
# Google Play Developer API — service account JSON for Play Billing verify/RTDN
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=com.flynnai.app

# Twilio Configuration (optional Expo client values; leave blank to avoid leaking secrets)
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=
EXPO_PUBLIC_TWILIO_WEBHOOK_URL=
EXPO_PUBLIC_TWILIO_LOOKUP_FUNCTION_URL=

# Push Notifications Configuration
# Get these from Firebase Console and Apple Developer Portal

# Android Push Notifications (Firebase Cloud Messaging HTTP v1 API)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# This will download a JSON file. Set GOOGLE_SERVICE_ACCOUNT_KEY to the entire JSON content (as a string)
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# iOS Push Notifications (Apple Push Notification service)
# Get from: Apple Developer Portal → Keys → Create APNs Auth Key
APNS_KEY_ID=your_10_char_apns_key_id
APNS_TEAM_ID=your_10_char_apple_team_id
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----"
APNS_BUNDLE_ID=com.flynnai.app
# Use sandbox for development, production for release builds
APNS_HOST=https://api.sandbox.push.apple.com

# Deepgram Voice Agent API Configuration
# API key from Deepgram Console (https://console.deepgram.com/)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# Voice Agent uses built-in Deepgram Aura-2 TTS (no separate TTS config needed)
# LLM provider is configured inline in Voice Agent (uses Gemini via Google AI Studio)

# Voice Profiles (for custom greetings)
VOICE_PROFILE_BUCKET=voice-profiles

# Field Service Integrations
# Jobber (https://developer.getjobber.com/)
EXPO_PUBLIC_JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
EXPO_PUBLIC_JOBBER_REDIRECT_URI=https://flynnai-telephony.fly.dev/integrations/jobber/callback

# Fergus (https://api.fergus.com/docs/)
EXPO_PUBLIC_FERGUS_CLIENT_ID=
FERGUS_CLIENT_SECRET=
EXPO_PUBLIC_FERGUS_REDIRECT_URI=

# ServiceTitan (https://developer.servicetitan.io/)
EXPO_PUBLIC_SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=
SERVICETITAN_TENANT_ID=
EXPO_PUBLIC_SERVICETITAN_REDIRECT_URI=

# Calendar Integrations
# Google Calendar
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=

# Calendly
EXPO_PUBLIC_CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
EXPO_PUBLIC_CALENDLY_REDIRECT_URI=

# ========================================
# Booking System Configuration
# ========================================
# Domain for public booking pages (e.g., flynnai.app/your-slug)
BOOKING_DOMAIN=flynnai.app

# Email Service (Resend - https://resend.com)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL="Flynn AI <noreply@flynnai.app>"

# Google Calendar OAuth (required for calendar integration)
# Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ========================================
# iMessage agent — tool-calling loop + Nango integrations
# ========================================
# The number Flynn answers iMessages on (the eSIM behind BlueBubbles). The
# contact card (contact.vcf) carries this so new texters save the right number.
FLYNN_IMESSAGE_NUMBER=+61495023092
# Master switch for the active-phase tool-calling agent loop. '1' = on.
# Off (default) keeps the legacy JSON intent routing — safe rollback path.
FLYNN_TOOL_LOOP=
# Nango Cloud (OAuth backbone). Routes /connect/:provider and /webhooks/nango
# only register when NANGO_SECRET_KEY is set.
NANGO_SECRET_KEY=
NANGO_HOST=https://api.nango.dev
# Webhook "Signing key" from Nango Environment Settings -> Webhooks (verifies
# the X-Nango-Hmac-Sha256 header on /webhooks/nango)
NANGO_WEBHOOK_SECRET=
# Signs the 7-day connect links Flynn texts (any long random string)
CONNECT_LINK_JWT_SECRET=
# Vision model for receipt extraction (DashScope, same compatible client)
VISION_LLM_MODEL=qwen3-vl-plus
# Encrypts integration logins (supplier/Xero/iCloud) at rest in
# user_integrations.credentials_encrypted. base64 32 bytes: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=

# Note: Add your actual values to .env file (not tracked in git)
