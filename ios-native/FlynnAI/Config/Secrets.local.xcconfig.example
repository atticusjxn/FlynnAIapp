// Copy this file to Secrets.local.xcconfig and fill in the values below.
// Secrets.local.xcconfig is gitignored and should never be committed.

// Supabase anon key (public-safe but kept out of the repo for hygiene).
// Copy from /app.config.js -> extra.supabaseAnonKey in the RN project.
SUPABASE_ANON_KEY =

// Stripe publishable key (pk_live_... or pk_test_...).
// Copy from /app.config.js -> extra.stripePublishableKey.
STRIPE_PUBLISHABLE_KEY =
