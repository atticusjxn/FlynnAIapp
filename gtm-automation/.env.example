# Copy to .env and fill in. Never commit .env.

# --- Airtable (FB groups, IG targets, daily log) ---
AIRTABLE_API_KEY=patxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx

# --- Instantly (cold email) ---
# Get from instantly.ai → Settings → Integrations → API
INSTANTLY_API_KEY=xxx
# Campaign ID for the existing "Flynn" campaign with 1k+ leads
INSTANTLY_CAMPAIGN_ID=xxx

# --- Apify (Google Maps scraper for AU tradies) ---
APIFY_TOKEN=apify_api_xxx
# Actor: compass/crawler-google-places (or another Google Maps actor)
APIFY_ACTOR_ID=compass~crawler-google-places

# --- Resend (morning brief email delivery) ---
RESEND_API_KEY=re_xxx
BRIEF_FROM_EMAIL=brief@flynn.ai
BRIEF_TO_EMAIL=atticusjxn@gmail.com

# --- Supabase (read yesterday's trial events from app) ---
SUPABASE_URL=https://zvfeafmmtfplzpnocyjw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- RevenueCat (paid conversions) ---
# REST API v2 secret key from app.revenuecat.com → Project Settings → API keys
REVENUECAT_API_KEY=sk_xxx
REVENUECAT_PROJECT_ID=xxx

# --- Date settings ---
TZ=Australia/Sydney

# --- Goal tracking ---
GOAL_PAID_CUSTOMERS=100
GOAL_DEADLINE=2026-06-30
GOAL_START_DATE=2026-05-08
