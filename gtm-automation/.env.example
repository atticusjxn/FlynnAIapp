# Copy to .env and fill in. Never commit .env.

# --- Resend (morning brief email delivery) ---
RESEND_API_KEY=re_xxx
BRIEF_FROM_EMAIL=brief@flynn.ai
BRIEF_TO_EMAIL=atticusjxn@gmail.com

# --- Supabase (reads trial_signups + writes gtm_* tables) ---
SUPABASE_URL=https://zvfeafmmtfplzpnocyjw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- RevenueCat (paid conversions) ---
# REST API v2 secret key from app.revenuecat.com → Project Settings → API keys
REVENUECAT_API_KEY=sk_xxx
REVENUECAT_PROJECT_ID=xxx

# --- Gmail API (cold-email sender, replaces Instantly) ---
# Create OAuth 2.0 Client ID at console.cloud.google.com → APIs & Services → Credentials.
# Application type: Desktop app. Download the JSON, copy id+secret here.
# Then run `npm run gmail:oauth` once to capture GMAIL_REFRESH_TOKEN.
GMAIL_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=GOCSPX-xxx
GMAIL_REFRESH_TOKEN=1//xxx
# Account that sends cold emails. Must match the Google account that granted consent.
GMAIL_FROM_EMAIL=atticus@flynn.ai
GMAIL_FROM_NAME=Atticus Jackson
# Hard cap to stay under Gmail abuse thresholds (free Gmail = 500/day soft cap;
# we run 30/day to look human and protect deliverability).
GMAIL_DAILY_CAP=30

# --- Date settings ---
TZ=Australia/Sydney

# --- Goal tracking ---
GOAL_PAID_CUSTOMERS=100
GOAL_DEADLINE=2026-06-30
GOAL_START_DATE=2026-05-08
